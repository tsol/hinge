{
  "name": "hinge",
  "version": "0.1.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/hinge.umd.js",
  "module": "./dist/hinge.es.js",
  "types": "./dist/hinge.d.ts",
  "exports": {
    ".": {
      "types": "./dist/hinge.d.ts",
      "import": "./dist/hinge.es.js",
      "require": "./dist/hinge.umd.js"
    },
    "./style.css": "./dist/hinge.css",
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./component": {
      "types": "./dist/component.d.ts",
      "import": "./dist/component.js"
    }
  },
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "vue-tsc --noEmit && vite build && vite build --config vite.plugin.config.ts && vite build --config vite.component.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0"
  }
}
